.page { padding: 24rpx; color: #222; }
.bold { font-weight: bold; }
.hint { color: #666; margin: 20rpx 0 10rpx; font-size: 28rpx; }

.tabs { display: flex; gap: 16rpx; margin-bottom: 8rpx; align-items: center; }
.tab { padding: 12rpx 28rpx; border: 1rpx solid #999; border-radius: 12rpx;
       background: #fff; font-size: 28rpx; }
.tab.small { padding: 6rpx 20rpx; font-size: 26rpx; }
.tab.active { background: #2c3e50; color: #fff; border-color: #2c3e50; }
.tabs.diff .hint { margin: 0; }

.tiles { display: flex; flex-wrap: wrap; gap: 8rpx; margin: 6rpx 0; }
.tile { display: flex; justify-content: center; align-items: center;
        width: 84rpx; height: 116rpx; box-sizing: border-box;
        border: 1rpx solid #b8b2a6; border-radius: 12rpx;
        background: linear-gradient(#fffef9, #f1ecdd);
        box-shadow: 0 3rpx 6rpx rgba(0, 0, 0, 0.18); }
.tile .face { width: 76rpx; height: 104rpx; }
.tile.selected { outline: 6rpx solid #2c3e50; }
.tile.good { background: #d4efdf; border-color: #27ae60; }
.tile.bad { background: #fadbd8; border-color: #c0392b; }
.tile.missed { background: #fcf3cf; border-color: #b7950b; }

.actions { display: flex; gap: 16rpx; margin: 28rpx 0; }
.btn { padding: 16rpx 40rpx; border: 1rpx solid #2c3e50; border-radius: 12rpx;
       background: #fff; color: #2c3e50; font-size: 30rpx; }
.btn.primary { background: #2c3e50; color: #fff; }

.verdict { font-weight: bold; font-size: 32rpx; margin: 16rpx 0; }
.verdict.ok { color: #1e8449; }
.verdict.no { color: #c0392b; }

.table { border: 1rpx solid #ccc; border-radius: 8rpx; margin-top: 16rpx;
         font-size: 28rpx; overflow: hidden; }
.tr { display: flex; border-top: 1rpx solid #ccc; }
.tr:first-child { border-top: none; }
.tr.th { font-weight: bold; background: #f4f4ef; }
.tr.best { background: #d4efdf; }
.td { flex: 1; padding: 10rpx 16rpx; }
.td.wide { flex: 2; }
