<view class="page">
  <view class="tabs">
    <view class="tab {{mode == 'settle' ? 'active' : ''}}" data-mode="settle" bindtap="switchMode">结账</view>
    <view class="tab {{mode == 'ting' ? 'active' : ''}}" data-mode="ting" bindtap="switchMode">听牌练习</view>
    <view class="tab {{mode == 'discard' ? 'active' : ''}}" data-mode="discard" bindtap="switchMode">下叫练习</view>
  </view>
  <view class="tabs diff" wx:if="{{mode != 'settle'}}">
    <view class="hint">难度：</view>
    <view class="tab small {{difficulty == 'easy' ? 'active' : ''}}" data-diff="easy" bindtap="setDifficulty">简单</view>
    <view class="tab small {{difficulty == 'normal' ? 'active' : ''}}" data-diff="normal" bindtap="setDifficulty">普通</view>
    <view class="tab small {{difficulty == 'hard' ? 'active' : ''}}" data-diff="hard" bindtap="setDifficulty">困难</view>
  </view>

  <block wx:if="{{mode == 'ting'}}">
    <view class="hint">手牌（已下叫）：</view>
    <view class="tiles">
      <view wx:for="{{hand}}" wx:key="index" class="tile">
        <image class="face" src="{{item.src}}" mode="aspectFit"/>
      </view>
    </view>
    <view class="hint">点选所有能胡的牌，然后提交：</view>
    <view wx:for="{{candidateRows}}" wx:for-item="row" wx:for-index="r" wx:key="r" class="tiles">
      <view wx:for="{{row}}" wx:key="index" data-r="{{r}}" data-i="{{index}}" bindtap="toggleTile"
            class="tile {{item.sel ? 'selected' : ''}} {{item.mark}}">
        <image class="face" src="{{item.src}}" mode="aspectFit"/>
      </view>
    </view>
  </block>

  <block wx:elif="{{mode == 'discard'}}">
    <view class="hint">定缺<text class="bold">{{missingName}}</text>，摸牌后 14 张。选出<text class="bold">所有</text>打出后能下叫的打法，每排点选一张：</view>
    <block wx:for="{{rows}}" wx:for-item="row" wx:for-index="r" wx:key="r">
      <view class="hint">{{row.label}}</view>
      <view class="tiles">
        <view wx:for="{{row.tiles}}" wx:key="index" data-r="{{r}}" data-i="{{index}}" bindtap="discardTap"
              class="tile {{item.sel ? 'selected' : ''}} {{item.mark}}">
          <image class="face" src="{{item.src}}" mode="aspectFit"/>
        </view>
      </view>
    </block>
  </block>

  <block wx:else>
    <view class="s-row"><text class="s-label">人数</text>
      <input class="num" type="number" value="{{sCount}}" bindinput="sCountInput"/></view>
    <view class="s-row"><text class="s-label">起始筹码</text>
      <input class="num" type="number" value="{{sInit}}" bindinput="sInitInput"/></view>
    <view class="hint">各家终局筹码：</view>
    <view class="s-row" wx:for="{{sChips}}" wx:key="index">
      <text class="s-label">玩家{{index + 1}}</text>
      <input class="num" type="number" value="{{item}}" data-i="{{index}}" bindinput="sChipInput"/>
    </view>
    <view class="s-row"><text class="s-label">茶钱筹码</text>
      <input class="num" type="number" value="{{sTea}}" bindinput="sTeaInput"/></view>
    <view class="actions">
      <view class="btn primary" bindtap="doSettle">结算</view>
    </view>
    <view class="verdict {{sBalanced ? 'ok' : 'no'}}">{{sCheck}}</view>
    <view wx:if="{{sRows.length > 0}}" class="table">
      <view class="tr th">
        <view class="td">玩家</view><view class="td">终局筹码</view><view class="td wide">输赢</view>
      </view>
      <view wx:for="{{sRows}}" wx:key="index" class="tr">
        <view class="td">{{item.name}}</view><view class="td">{{item.chips}}</view>
        <view class="td wide {{item.cls}}">{{item.text}}</view>
      </view>
    </view>
    <view class="hint" wx:if="{{sRows.length > 0}}">茶钱已按人数平分补回（每人 +{{sShare}}）；茶钱现金另行结算。</view>
  </block>

  <view class="actions" wx:if="{{mode != 'settle'}}">
    <view class="btn primary" bindtap="submit">提交</view>
    <view class="btn" bindtap="next">下一题</view>
  </view>

  <view class="verdict {{verdictOk ? 'ok' : 'no'}}">{{verdict}}</view>

  <view wx:if="{{tingRows.length > 0}}" class="table">
    <view class="tr th">
      <view class="td">胡牌</view><view class="td">倍数</view><view class="td wide">番型</view>
    </view>
    <view wx:for="{{tingRows}}" wx:key="index" class="tr">
      <view class="td">{{item.text}}</view><view class="td">{{item.fan}} 倍</view><view class="td wide">{{item.patterns}}</view>
    </view>
  </view>

  <view wx:if="{{discardRows.length > 0}}" class="table">
    <view class="tr th">
      <view class="td">下叫打法</view><view class="td wide">听牌</view>
    </view>
    <view wx:for="{{discardRows}}" wx:key="index" class="tr best">
      <view class="td">打 {{item.text}}</view><view class="td wide">{{item.waits}}</view>
    </view>
  </view>

  <view class="hint" wx:if="{{footnote}}">{{footnote}}</view>
</view>
